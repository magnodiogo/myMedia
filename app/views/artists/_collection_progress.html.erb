<section style="display: grid; gap: 1.5rem;">
  <div style="border: 1px solid var(--panel-border); border-radius: var(--border-radius, 12px); padding: 1.25rem; background-color: rgba(255, 255, 255, 0.03);">
    <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; flex-wrap: wrap;">
      <div>
        <h3 style="margin: 0 0 0.35rem; color: var(--text-main); font-size: 1.1rem;">Overall artist progress</h3>
        <p style="margin: 0; color: var(--text-muted); font-size: 0.9rem;">
          <%= collection_progress[:owned_count] %> of <%= collection_progress[:total_count] %> catalog albums owned
        </p>
      </div>
      <strong style="color: var(--text-main); font-size: 1.35rem;"><%= collection_progress[:percentage] %>%</strong>
    </div>
    <div style="height: 8px; margin-top: 1rem; background-color: rgba(255, 255, 255, 0.08); border-radius: 999px; overflow: hidden;">
      <div style="height: 100%; width: <%= collection_progress[:percentage] %>%; background-color: #6366f1;"></div>
    </div>
  </div>

  <div>
    <h3 style="margin: 0 0 1rem; color: var(--text-main); font-size: 1.1rem;">Album type progress</h3>
    <% if album_type_progress.any? %>
      <div style="display: grid; gap: 0.75rem;">
        <% album_type_progress.each do |entry| %>
          <% progress = entry[:progress] %>
          <div style="border: 1px solid var(--panel-border); border-radius: var(--border-radius, 12px); padding: 1rem; background-color: rgba(255, 255, 255, 0.02);">
            <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; flex-wrap: wrap;">
              <div>
                <strong style="color: var(--text-main);"><%= entry[:album_type].humanize %></strong>
                <p style="margin: 0.25rem 0 0; color: var(--text-muted); font-size: 0.85rem;">
                  <%= progress[:owned_count] %> of <%= progress[:total_count] %> albums owned
                </p>
              </div>
              <span style="color: var(--text-main); font-weight: 600;"><%= progress[:percentage] %>%</span>
            </div>
            <div style="height: 6px; margin-top: 0.85rem; background-color: rgba(255, 255, 255, 0.08); border-radius: 999px; overflow: hidden;">
              <div style="height: 100%; width: <%= progress[:percentage] %>%; background-color: #6366f1;"></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p style="color: var(--text-muted); margin: 0;">No albums have been registered for this artist yet.</p>
    <% end %>
  </div>

  <div>
    <h3 style="margin: 0 0 1rem; color: var(--text-main); font-size: 1.1rem;">Era progress</h3>
    <% if artist_era_progress.any? %>
      <div style="display: grid; gap: 0.75rem;">
        <% artist_era_progress.each do |entry| %>
          <% era = entry[:artist_era] %>
          <% progress = entry[:progress] %>
          <div style="border: 1px solid var(--panel-border); border-radius: var(--border-radius, 12px); padding: 1rem; background-color: rgba(255, 255, 255, 0.02);">
            <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; flex-wrap: wrap;">
              <div>
                <strong style="color: var(--text-main);"><%= era.name %></strong>
                <p style="margin: 0.25rem 0 0; color: var(--text-muted); font-size: 0.85rem;">
                  <%= progress[:owned_count] %> of <%= progress[:total_count] %> albums owned
                </p>
              </div>
              <span style="color: var(--text-main); font-weight: 600;"><%= progress[:percentage] %>%</span>
            </div>
            <div style="height: 6px; margin-top: 0.85rem; background-color: rgba(255, 255, 255, 0.08); border-radius: 999px; overflow: hidden;">
              <div style="height: 100%; width: <%= progress[:percentage] %>%; background-color: #6366f1;"></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p style="color: var(--text-muted); margin: 0;">No eras have been defined for this artist yet.</p>
    <% end %>
  </div>
</section>
