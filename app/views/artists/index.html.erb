<div class="page-header">
  <div>
    <h1 class="page-title">Artists</h1>
    <p class="page-subtitle">Browse artists and explore their discographies</p>
  </div>
  <% if current_user&.admin? %>
    <a href="<%= new_artist_path %>" class="btn btn-primary">+ Add Artist</a>
  <% end %>
</div>

<div class="section-box">
  <%= form_with url: artists_path, method: :get, local: true, style: "display: flex; gap: 0.75rem; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap;" do |form| %>
    <%= form.search_field :q, value: @query, placeholder: "Search artists", class: "form-control", style: "min-width: min(100%, 320px); flex: 1;" %>
    <%= form.submit "Search", class: "btn btn-primary" %>
    <% if @query.present? %>
      <%= link_to "Clear", artists_path, class: "btn btn-secondary" %>
    <% end %>
  <% end %>

  <% if @artists.any? %>
    <% if current_user&.admin? %>
      <table class="custom-table">
        <thead>
          <tr>
            <th style="width: 60px;">Photo</th>
            <th>Name</th>
            <th>Bio</th>
            <th style="text-align: right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @artists.each do |artist| %>
            <tr>
              <td>
                <% if artist.photo.attached? %>
                  <%= image_tag artist.photo, style: "width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" %>
                <% else %>
                  <div style="width: 40px; height: 40px; border-radius: 50%; background-color: rgba(99, 102, 241, 0.15); color: #a5b4fc; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; font-weight: 700; border: 1px solid rgba(99, 102, 241, 0.3);"><%= artist.initials %></div>
                <% end %>
              </td>
              <td style="font-weight: 600; color: #a5b4fc; vertical-align: middle;">
                <a href="<%= artist_path(artist) %>" style="color: #a5b4fc; text-decoration: none;"><%= artist.name %></a>
              </td>
              <td style="color: var(--text-muted); vertical-align: middle;"><%= truncate(artist.bio, length: 80) %></td>
              <td style="text-align: right; vertical-align: middle;">
                <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                  <a href="<%= artist_path(artist) %>" class="btn btn-secondary btn-sm">View</a>
                  <a href="<%= edit_artist_path(artist) %>" class="btn btn-secondary btn-sm">Edit</a>
                  <%= button_to "Delete", artist_path(artist), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="artists-grid">
        <% @artists.each do |artist| %>
          <div class="artist-card">
            <a href="<%= artist_path(artist) %>" class="artist-card-link">
              <div class="artist-photo-container">
                <% if artist.photo.attached? %>
                  <%= image_tag artist.photo, class: "artist-photo" %>
                <% else %>
                  <div class="artist-photo-placeholder" style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(30, 41, 59, 0.8) 100%);">
                    <span class="placeholder-icon" style="font-weight: 700; color: #a5b4fc; opacity: 0.85; font-size: 2.4rem; letter-spacing: -0.5px;"><%= artist.initials %></span>
                  </div>
                <% end %>
              </div>
              <div class="artist-name"><%= artist.name %></div>
            </a>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <% if @query.present? %>
      <p style="color: var(--text-muted); padding: 1rem 0;">No artists found for "<%= @query %>".</p>
    <% elsif current_user&.admin? %>
      <p style="color: var(--text-muted); padding: 1rem 0;">No artists registered yet. Click "+ Add Artist" to create one.</p>
    <% else %>
      <p style="color: var(--text-muted); padding: 1rem 0;">No artists registered yet.</p>
    <% end %>
  <% end %>
</div>
