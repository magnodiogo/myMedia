<turbo-frame id="lyrics_frame">
  <div class="lyrics-show-container" style="color: var(--text-color); font-size: 1.05rem; line-height: 1.6; white-space: pre-wrap; max-height: 400px; overflow-y: auto; padding: 1.5rem; background: rgba(255, 255, 255, 0.02); border-radius: var(--border-radius); border: 1px solid var(--panel-border);"><%= @track.lyrics.to_s.strip.presence || "No lyrics available for this song." %></div>
  
  <div style="display: flex; justify-content: flex-end; margin-top: 1.5rem;">
    <button type="button" class="btn btn-secondary" data-action="click->lyrics-modal#close">Close</button>
  </div>
</turbo-frame>
