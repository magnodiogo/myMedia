<div class="page-header">
  <div>
    <h1 class="page-title">Admin Dashboard</h1>
    <p class="page-subtitle">Company-wide overview and user statistics</p>
  </div>
  <% if current_user&.admin? %>
    <a href="<%= new_media_path %>" class="btn btn-primary">+ Add Physical Media</a>
  <% end %>
</div>

<!-- Main Stats Grid -->
<div class="stats-grid">
  <div class="stat-card admin-stat-card-glow">
    <div class="stat-icon-bg">👥</div>
    <div class="stat-info">
      <div class="stat-label">Total Users</div>
      <div class="stat-value"><%= @total_users %></div>
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
        <%= @total_common_users %> Common • <%= @total_admin_users %> Admin
      </div>
    </div>
  </div>
  <div class="stat-card admin-stat-card-glow">
    <div class="stat-icon-bg">💿</div>
    <div class="stat-info">
      <div class="stat-label">Physical Media Records</div>
      <div class="stat-value"><%= @total_unique_media %></div>
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
        Album editions and pressings
      </div>
    </div>
  </div>
  <div class="stat-card admin-stat-card-glow">
    <div class="stat-icon-bg">📦</div>
    <div class="stat-info">
      <div class="stat-label">Items Collected</div>
      <div class="stat-value"><%= @total_user_media %></div>
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
        Total owned copies
      </div>
    </div>
  </div>
  <div class="stat-card admin-stat-card-glow">
    <div class="stat-icon-bg">🎤</div>
    <div class="stat-info">
      <div class="stat-label">Total Artists</div>
      <div class="stat-value"><%= @total_artists %></div>
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
        In database catalog
      </div>
    </div>
  </div>
</div>

<!-- Subscription & Revenue Stats -->
<h3 style="margin-top: 2.5rem; margin-bottom: 1.25rem; color: var(--text-main); font-weight: 600; display: flex; align-items: center; gap: 0.5rem; font-size: 1.25rem;">
  <span>💎</span> Subscription & Revenue Overview
</h3>
<div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem;">
  <div class="stat-card" style="border-left: 4px solid #a855f7; box-shadow: 0 4px 15px rgba(168, 85, 247, 0.05); transition: transform 0.2s ease;">
    <div class="stat-icon-bg" style="color: #c084fc;">💎</div>
    <div class="stat-info">
      <div class="stat-label">Premium Subscribers</div>
      <div class="stat-value" style="color: #c084fc;"><%= @premium_users_count %></div>
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
        Paid subscription active
      </div>
    </div>
  </div>
  
  <div class="stat-card" style="border-left: 4px solid var(--accent-primary); box-shadow: 0 4px 15px rgba(99, 102, 241, 0.05); transition: transform 0.2s ease;">
    <div class="stat-icon-bg" style="color: var(--accent-primary);">👥</div>
    <div class="stat-info">
      <div class="stat-label">Free Users</div>
      <div class="stat-value"><%= @free_users_count %></div>
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
        Subject to media limit
      </div>
    </div>
  </div>

  <div class="stat-card" style="border-left: 4px solid #10b981; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.05); transition: transform 0.2s ease;">
    <div class="stat-icon-bg" style="color: #34d399;">💵</div>
    <div class="stat-info">
      <div class="stat-label">Est. Monthly Revenue</div>
      <div class="stat-value" style="background: linear-gradient(135deg, #34d399 0%, #059669 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        <%= number_to_currency(@monthly_revenue_estimation, unit: "R$ ") %>
      </div>
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
        Based on active monthly & yearly plans
      </div>
    </div>
  </div>

  <div class="stat-card" style="border-left: 4px solid #f59e0b; box-shadow: 0 4px 15px rgba(245, 158, 11, 0.05); transition: transform 0.2s ease;">
    <div class="stat-icon-bg" style="color: #fbbf24;">📈</div>
    <div class="stat-info">
      <div class="stat-label">Est. Annual Revenue</div>
      <div class="stat-value" style="background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        <%= number_to_currency(@annual_revenue_estimation, unit: "R$ ") %>
      </div>
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">
        Projected yearly revenue
      </div>
    </div>
  </div>
</div>

<!-- Highlight Section -->
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem;">
  <!-- Last Added Item Widget -->
  <div class="admin-highlight-card">
    <div class="admin-highlight-label">⚡ Last Addition</div>
    <% if @last_addition %>
      <div style="display: flex; gap: 1rem; align-items: center; margin-top: 0.75rem;">
        <% if @last_media_added&.cover_image&.attached? %>
          <%= image_tag @last_media_added.cover_image, style: "width: 64px; height: 64px; border-radius: var(--border-radius); object-fit: cover; border: 1px solid var(--panel-border);" %>
        <% else %>
          <div style="width: 64px; height: 64px; border-radius: var(--border-radius); background: rgba(255,255,255,0.03); border: 1px solid var(--panel-border); display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">💿</div>
        <% end %>
        <div style="flex: 1;">
          <h4 style="margin: 0; font-size: 1.05rem; font-weight: 600;"><%= @last_media_added&.album&.title || @last_media_added&.title %></h4>
          <p style="margin: 0.15rem 0 0 0; font-size: 0.85rem; color: var(--text-muted);"><%= @last_media_added&.artist&.name %></p>
          <div style="margin-top: 0.4rem; display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem;">
            <span style="color: var(--text-muted);">By:</span>
            <span style="font-weight: 500; color: var(--text-main);"><%= @last_user_added&.name.presence || @last_user_added&.email %></span>
            <span style="color: var(--text-muted);">•</span>
            <span style="color: var(--accent-secondary);"><%= time_ago_in_words(@last_addition.created_at) %> ago</span>
          </div>
        </div>
      </div>
    <% else %>
      <div style="padding: 1rem 0; color: var(--text-muted); font-size: 0.9rem;">
        No physical media additions recorded in the system yet.
      </div>
    <% end %>
  </div>

  <!-- Top Collector Widget -->
  <div class="admin-highlight-card">
    <div class="admin-highlight-label">🏆 Top Collector</div>
    <% if @top_user %>
      <div style="display: flex; gap: 1rem; align-items: center; margin-top: 0.75rem;">
        <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--accent-gradient); display: flex; align-items: center; justify-content: center; font-size: 1.8rem; box-shadow: 0 4px 15px var(--accent-glow);">
          👑
        </div>
        <div style="flex: 1;">
          <h4 style="margin: 0; font-size: 1.15rem; font-weight: 700; color: var(--text-main);"><%= @top_user.name.presence || @top_user.email %></h4>
          <p style="margin: 0.15rem 0 0 0; font-size: 0.85rem; color: var(--text-muted);">
            Active member of the company collection
          </p>
          <div style="margin-top: 0.4rem; display: inline-flex; align-items: center; background: rgba(139, 92, 246, 0.15); border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 20px; padding: 0.15rem 0.65rem; font-size: 0.78rem; font-weight: 600; color: #c7d2fe;">
            <%= @top_user_count %> <%= @top_user_count == 1 ? 'item' : 'items' %> owned
          </div>
        </div>
      </div>
    <% else %>
      <div style="padding: 1rem 0; color: var(--text-muted); font-size: 0.9rem;">
        No collectors found.
      </div>
    <% end %>
  </div>
</div>

<!-- Tables & Format Breakdown -->
<div class="dashboard-sections">
  <div style="display: flex; flex-direction: column; gap: 2rem;">
    <!-- Top 5 Collectors list -->
    <div class="section-box">
      <h3>
        <span>Top 5 Collectors</span>
      </h3>
      <table class="admin-table">
        <thead>
          <tr>
            <th style="width: 80px;">Rank</th>
            <th>Collector Name / Email</th>
            <th style="text-align: right; width: 150px;">Items Collected</th>
            <th style="text-align: center; width: 120px;">Role</th>
          </tr>
        </thead>
        <tbody>
          <% @top_users.each_with_index do |user, index| %>
            <tr>
              <td>
                <span style="font-weight: 700; font-size: 0.95rem; color: <%= index == 0 ? 'var(--accent-secondary)' : 'var(--text-main)' %>">
                  #<%= index + 1 %>
                </span>
              </td>
              <td>
                <div class="admin-user-info-cell">
                  <div class="admin-user-avatar">
                    <%= user.name.presence ? user.name[0].upcase : user.email[0].upcase %>
                  </div>
                  <div>
                    <span class="admin-user-name-small"><%= user.name.presence || "Anonymous Collector" %></span>
                    <span class="admin-user-email-small"><%= user.email %></span>
                  </div>
                </div>
              </td>
              <td style="text-align: right; font-weight: 600; color: var(--text-main);">
                <%= user.media_count %>
              </td>
              <td style="text-align: center;">
                <% if user.type == 'AdminUser' %>
                  <span class="media-badge admin-badge" style="font-size: 0.65rem; padding: 0.1rem 0.4rem; margin: 0;">Admin</span>
                <% else %>
                  <span class="media-badge" style="font-size: 0.65rem; padding: 0.1rem 0.4rem; margin: 0; background-color: rgba(255,255,255,0.05); border-color: var(--panel-border); color: var(--text-muted);">Collector</span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @top_users.empty? %>
            <tr>
              <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 2rem 0;">No collectors registered yet.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Recent Activity -->
    <div class="section-box">
      <h3>
        <span>Recent Activity</span>
      </h3>
      <div style="display: flex; flex-direction: column;">
        <% @recent_additions.each do |addition| %>
          <div class="admin-activity-item">
            <div class="admin-activity-media">
              <% if addition.media&.cover_image&.attached? %>
                <%= image_tag addition.media.cover_image, class: "admin-activity-cover" %>
              <% else %>
                <div class="admin-activity-cover-placeholder">💿</div>
              <% end %>
              <div>
                <a href="<%= media_path(addition.media) %>" style="font-weight: 600; color: var(--text-main); text-decoration: none; font-size: 0.95rem;">
                  <%= addition.media&.album&.title || addition.media&.title %>
                </a>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.15rem;">
                  <%= addition.media&.artist&.name %> • <%= addition.media&.media_type&.name %>
                </div>
              </div>
            </div>
            <div style="text-align: right;">
              <span style="font-size: 0.85rem; font-weight: 500; color: var(--text-main);"><%= addition.user&.name.presence || addition.user&.email %></span>
              <div class="admin-activity-time"><%= time_ago_in_words(addition.created_at) %> ago</div>
            </div>
          </div>
        <% end %>
        <% if @recent_additions.empty? %>
          <p style="color: var(--text-muted); padding: 1rem 0; text-align: center; margin: 0;">No additions recorded yet.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Format Distribution (Company Wide) -->
  <div class="section-box">
    <h3>
      <span>Format Breakdown</span>
    </h3>
    <div class="dashboard-list">
      <% @media_types_with_count.each do |(id, name), count| %>
        <% pct = @total_user_media > 0 ? (count.to_f / @total_user_media * 100).round : 0 %>
        <div class="dashboard-item format-item" style="flex-direction: column; align-items: stretch; gap: 0.6rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
            <span class="dashboard-item-title"><%= name %></span>
            <span class="format-count-badge"><%= count %> <%= count == 1 ? 'item' : 'items' %> (<%= pct %>%)</span>
          </div>
          <div class="format-progress-bar-bg">
            <div class="format-progress-bar-fill" style="width: <%= pct %>%; background: var(--accent-gradient);"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
