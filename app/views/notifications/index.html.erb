<div class="page-header">
  <div>
    <h1 class="page-title">Notifications</h1>
    <p class="page-subtitle">Announcements, updates, and messages from the team</p>
  </div>
  <% if @notifications.any? { |n| !n.read? } %>
    <div>
      <%= button_to "Mark all as read", read_all_notifications_path, method: :post, class: "btn btn-secondary", style: "background-color: rgba(99, 102, 241, 0.1); border-color: rgba(99, 102, 241, 0.3); color: #a5b4fc; font-weight: 500;" %>
    </div>
  <% end %>
</div>

<div class="section-box" style="padding: 1.5rem;">
  <% if @notifications.any? %>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <% @notifications.each do |notification| %>
        <div class="glass-card" style="display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; padding: 1.25rem; border-color: <%= notification.read? ? 'var(--panel-border)' : 'var(--accent-primary)' %>; background: <%= notification.read? ? 'rgba(20, 26, 45, 0.4)' : 'linear-gradient(135deg, rgba(20, 26, 45, 0.8) 0%, rgba(30, 41, 59, 0.8) 100%)' %>; position: relative;">
          
          <% unless notification.read? %>
            <div style="position: absolute; top: 1.25rem; left: 0.5rem; width: 8px; height: 8px; border-radius: 50%; background-color: var(--accent-primary); box-shadow: 0 0 8px var(--accent-glow);"></div>
          <% end %>

          <a href="<%= notification_path(notification) %>" style="text-decoration: none; flex: 1; margin-left: <%= notification.read? ? '0' : '0.5rem' %>; display: flex; flex-direction: column; gap: 0.3rem;">
            <div style="font-weight: 700; font-size: 1.05rem; color: <%= notification.read? ? 'var(--text-muted)' : 'var(--text-main)' %>; display: flex; align-items: center; gap: 0.5rem;">
              <%= notification.title %>
            </div>
            <div style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
              <%= notification.content %>
            </div>
            <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.2rem;">
              Sent <%= time_ago_in_words(notification.created_at) %> ago
            </div>
          </a>

          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <a href="<%= notification_path(notification) %>" class="btn btn-secondary btn-sm">Read</a>
            <%= button_to notification_path(notification), method: :delete, class: "btn btn-danger btn-sm", style: "background-color: rgba(239, 68, 68, 0.05); border-color: rgba(239, 68, 68, 0.15); font-size: 0.8rem; padding: 0.3rem 0.6rem;", data: { confirm: "Are you sure?" } do %>
              🗑️
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div style="text-align: center; padding: 3rem 1.5rem; color: var(--text-muted);">
      <div style="font-size: 3rem; margin-bottom: 1rem;">🔔</div>
      <h3 style="margin-bottom: 0.5rem; font-weight: 600; color: var(--text-main);">All Caught Up!</h3>
      <p style="font-size: 0.9rem;">You have no notifications or messages at the moment.</p>
    </div>
  <% end %>
</div>
