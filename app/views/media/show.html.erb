<div class="media-detail-container" data-controller="lyrics-modal">
  <% if @media.cover_image.attached? %>
    <div class="media-detail-backdrop" style="background-image: url('<%= rails_blob_path(@media.cover_image) %>');"></div>
  <% end %>

  <div class="media-detail-content-wrapper">
    <div class="page-header media-detail-header">
      <div>
        <span class="media-badge detail-badge"><%= @media.media_type.name %></span>
        <h1 class="page-title detail-title"><%= @media.album&.title || @media.title %></h1>
        <p class="page-subtitle detail-subtitle">by <%= link_to @media.artist.name, artist_path(@media.artist), style: "color: #a5b4fc; text-decoration: none;" %></p>
        <% if @media.album && @media.title != @media.album.title %>
          <p class="page-subtitle detail-subtitle">Edition: <%= @media.title %></p>
        <% end %>
      </div>
      <div class="media-detail-actions">
        <% if current_user&.admin? %>
          <%= button_to "🔄 Refresh Data", refresh_metadata_media_path(@media), method: :post, class: "btn btn-secondary" %>
          <a href="<%= edit_media_path(@media) %>" class="btn btn-secondary">Edit</a>
          <%= button_to "Delete", media_path(@media), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
        <% end %>
        <a href="<%= media_index_path %>" class="btn btn-secondary">Back</a>
      </div>
    </div>

    <div class="spec-card-premium">
      <div class="spec-card-cover-side">
        <% if @media.cover_image.attached? %>
          <div class="detail-cover-wrapper">
            <%= image_tag @media.cover_image, class: "detail-cover" %>
          </div>
        <% else %>
          <div class="detail-cover-placeholder">
            <span class="placeholder-icon">🎵</span>
          </div>
        <% end %>
      </div>

      <div class="spec-card-info-side">
        <div class="spec-header">
          <h2>Physical Edition</h2>
        </div>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-label">Album</span>
            <span class="spec-value"><%= @media.album&.title || @media.title %></span>
          </div>

          <div class="spec-item">
            <span class="spec-label">Artist</span>
            <span class="spec-value"><%= @media.artist.name %></span>
          </div>

          <div class="spec-item">
            <span class="spec-label">Physical Format</span>
            <span class="spec-value highlight-value"><%= @media.media_type.name %></span>
          </div>

          <div class="spec-item">
            <span class="spec-label">Edition Release Year</span>
            <span class="spec-value"><%= @media.release_year.presence || "Unknown" %></span>
          </div>

          <div class="spec-item">
            <span class="spec-label">Catalog Number</span>
            <span class="spec-value code-value"><%= @media.catalog_number.presence || "N/A" %></span>
          </div>

          <div class="spec-item">
            <span class="spec-label">Barcode</span>
            <span class="spec-value code-value"><%= @media.barcode.presence || "N/A" %></span>
          </div>

          <div class="spec-item">
            <span class="spec-label">Duration</span>
            <span class="spec-value"><%= @media.formatted_duration.presence || "Unknown" %></span>
          </div>

          <div class="spec-item">
            <span class="spec-label">Genre</span>
            <span class="spec-value"><%= @media.media_genres.map(&:name).join(", ").presence || "Unknown" %></span>
          </div>

          <div class="spec-item">
            <span class="spec-label">Styles</span>
            <span class="spec-value"><%= @media.media_styles.map(&:name).join(", ").presence || "Unknown" %></span>
          </div>

          <div class="spec-item">
            <span class="spec-label">Recording Location</span>
            <span class="spec-value"><%= @media.recording_locations.map(&:name).join(", ").presence || "Unknown" %></span>
          </div>
        </div>

        <% if @media.notes.present? %>
          <div class="spec-notes">
            <h3>Edition Notes</h3>
            <div class="collector-notes-content">
              <span class="notes-quote-mark">"</span>
              <p><%= @media.notes %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Bottom Tabs Card -->
    <div class="detail-tabs-card" data-controller="tabs">
      <div class="tabs-header">
        <button class="tab-link active" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="tracks">
          🎵 Tracks
        </button>
        <button class="tab-link" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="info">
          ℹ️ Album Info
        </button>
        <button class="tab-link" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="credits">
          Credits
        </button>
        <% if current_user %>
          <button class="tab-link" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="collection">
            ⭐ My Copy
          </button>
        <% end %>
        <button class="tab-link" data-action="click->tabs#switch" data-tabs-target="tab" data-tab-id="notes">
          📝 Edition Notes
        </button>
      </div>

      <!-- Tracks Panel -->
      <div class="tab-panel" data-tabs-target="panel" data-tab-id="tracks">
        <div class="track-table-container">
          <div class="track-table" style="display: table; width: 100%;">
            <div class="track-table-header" style="display: table-row; font-weight: bold; border-bottom: 1px solid var(--panel-border);">
              <div style="display: table-cell; padding: 0.75rem 1rem; color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase;">No.</div>
              <div style="display: table-cell; padding: 0.75rem 1rem; color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase;">Track Title</div>
              <div style="display: table-cell; padding: 0.75rem 1rem; color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; text-align: right;">Duration</div>
              <div style="display: table-cell; padding: 0.75rem 1rem; color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; text-align: right;">Actions</div>
            </div>
            
            <div id="tracks_list" style="display: table-row-group;">
              <%= render partial: "tracks/track", collection: @media.tracks, as: :track, locals: { media: @media } %>
            </div>
          </div>
        </div>

        <% if current_user&.admin? %>
          <div id="new_track_form_wrapper" class="track-inline-form-wrapper">
            <h4 class="track-inline-form-title">⚡ Add New Track</h4>
            <%= render partial: "tracks/form", locals: { media: @media, track: @media.tracks.build(track_number: @media.tracks.maximum(:track_number).to_i + 1) } %>
          </div>
        <% end %>
      </div>

      <!-- Info Panel -->
      <div class="tab-panel" data-tabs-target="panel" data-tab-id="info" style="display: none;">
        <% album_info = @media.album&.summary.presence || @media.info.presence %>
        <% if album_info.present? %>
          <div class="wiki-info-content" style="padding: 1.5rem; background: rgba(255, 255, 255, 0.01); border-radius: var(--border-radius); border: 1px solid var(--panel-border);">
            <p style="margin: 0; color: var(--text-color); font-size: 1.05rem; line-height: 1.6;"><%= album_info %></p>
          </div>
        <% else %>
          <p style="color: var(--text-muted); font-style: italic; text-align: center; padding: 2rem 0;">No album information available yet.</p>
        <% end %>
      </div>

      <div class="tab-panel" data-tabs-target="panel" data-tab-id="credits" style="display: none;">
        <% if @media.album_credits.any? %>
          <% [
            ["Musicians", @album_credits_by_category["musician"]],
            ["Production & Artwork", @album_credits_by_category["technical"]]
          ].each do |title, credits| %>
            <% next if credits.blank? %>
            <div class="participants-list" style="margin-bottom: 1.5rem;">
              <h3 style="margin: 0 0 1rem; color: var(--text-main);"><%= title %></h3>
              <% credits.group_by { |credit| credit.credit_person || credit.person_name }.each do |person, person_credits| %>
                <div class="participant-row">
                  <strong>
                    <% if person.respond_to?(:id) %>
                      <%= link_to person.name, credit_person_path(person), style: "color: inherit; text-decoration: none;" %>
                    <% else %>
                      <%= person %>
                    <% end %>
                  </strong>
                  <span><%= person_credits.map(&:role).uniq.join(", ") %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <p style="color: var(--text-muted); font-style: italic; text-align: center; padding: 2rem 0;">No album credits imported yet.</p>
        <% end %>
      </div>

      <!-- Collection Panel -->
      <% if current_user %>
      <div class="tab-panel" data-tabs-target="panel" data-tab-id="collection" style="display: none;">
        <div class="collection-form-container" style="padding: 2rem; background: rgba(20, 26, 45, 0.4); border-radius: var(--border-radius); border: 1px solid var(--panel-border); backdrop-filter: blur(12px);">
          <%= form_with model: @user_media, class: "modern-form" do |f| %>
            <%= f.hidden_field :media_id %>
            
            <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
              <div class="form-group">
                <%= f.label :condition, "Media Condition", class: "form-label" %>
                <%= f.select :condition, UserMedia::CONDITIONS, { include_blank: "Select Condition" }, class: "form-control" %>
              </div>
              <div class="form-group">
                <%= f.label :sleeve_condition, "Sleeve Condition", class: "form-label" %>
                <%= f.select :sleeve_condition, UserMedia::CONDITIONS, { include_blank: "Select Sleeve Condition" }, class: "form-control" %>
              </div>
              <div class="form-group">
                <%= f.label :price_paid, "Price Paid", class: "form-label" %>
                <div style="display: flex; gap: 0.5rem;">
                  <%= f.select :currency, UserMedia::CURRENCIES, {}, class: "form-control", style: "width: 90px;" %>
                  <%= f.number_field :price_paid, class: "form-control", step: "0.01", style: "flex: 1;" %>
                </div>
              </div>
              <div class="form-group">
                <%= f.label :purchase_date, "Purchase Date", class: "form-label" %>
                <%= f.date_field :purchase_date, class: "form-control" %>
              </div>
              <div class="form-group">
                <%= f.label :purchase_location, "Purchase Location", class: "form-label" %>
                <%= f.text_field :purchase_location, class: "form-control", placeholder: "Store, Online, Discogs..." %>
              </div>
              <div class="form-group">
                <%= f.label :physical_location, "Physical Location", class: "form-label" %>
                <%= f.text_field :physical_location, class: "form-control", placeholder: "Shelf A, Box 2..." %>
              </div>
              <div class="form-group" style="grid-column: 1 / -1;">
                <%= f.label :edition_notes, "Edition Notes", class: "form-label" %>
                <%= f.text_field :edition_notes, class: "form-control", placeholder: "e.g., 1st Pressing, Limited Edition" %>
              </div>
            </div>

            <div class="form-checkboxes" style="display: flex; flex-wrap: wrap; gap: 2rem; margin-bottom: 2rem; padding: 0.5rem 0;">
              <div style="display: flex; align-items: center; gap: 0.75rem;">
                <div class="custom-checkbox-wrapper">
                  <%= f.check_box :is_signed, class: "custom-checkbox-input" %>
                  <span class="custom-checkbox-checkmark"></span>
                </div>
                <%= f.label :is_signed, "Signed / Autographed", style: "cursor: pointer; font-size: 0.95rem; color: var(--text-main); font-weight: 500; user-select: none;" %>
              </div>
              
              <div style="display: flex; align-items: center; gap: 0.75rem;">
                <div class="custom-checkbox-wrapper">
                  <%= f.check_box :is_sealed, class: "custom-checkbox-input" %>
                  <span class="custom-checkbox-checkmark"></span>
                </div>
                <%= f.label :is_sealed, "Still Sealed", style: "cursor: pointer; font-size: 0.95rem; color: var(--text-main); font-weight: 500; user-select: none;" %>
              </div>
            </div>

            <div class="form-group" style="margin-bottom: 1.5rem;">
              <%= f.label :notes, "Personal Notes", class: "form-label" %>
              <%= f.text_area :notes, class: "form-control", rows: 3, placeholder: "Any personal notes or memories about this item..." %>
            </div>

            <div class="form-actions" style="display: flex; justify-content: flex-end; gap: 1rem; border-top: 1px solid var(--panel-border); padding-top: 1.5rem;">
              <%= f.submit @user_media.persisted? ? "Update My Copy" : "Save to My Collection", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
      <% end %>

      <!-- Notes Panel -->
      <div class="tab-panel" data-tabs-target="panel" data-tab-id="notes" style="display: none;">
        <% if @media.notes.present? %>
          <div class="collector-notes-content" style="margin-top: 0; padding: 1.5rem; background: rgba(255, 255, 255, 0.01); border-radius: var(--border-radius); border: 1px solid var(--panel-border);">
            <span class="notes-quote-mark" style="font-size: 3.5rem; line-height: 1; color: var(--primary-color); opacity: 0.2; float: left; margin-right: 0.5rem; margin-top: -1rem;">"</span>
            <p style="margin: 0; color: var(--text-color); font-size: 1.05rem; line-height: 1.6; font-style: italic;"><%= @media.notes %></p>
          </div>
        <% else %>
          <p style="color: var(--text-muted); font-style: italic; text-align: center; padding: 2rem 0;">No edition notes registered for this physical media.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Keep the lyrics modal outside containers with overflow hidden so fixed positioning works. -->
  <div id="lyrics-modal" class="modal-overlay" data-lyrics-modal-target="modal">
    <div class="modal-content" style="max-width: 650px;">
      <div class="modal-header">
        <h2 data-lyrics-modal-target="title">Lyrics</h2>
        <button type="button" class="modal-close-btn" data-action="click->lyrics-modal#close">&times;</button>
      </div>
      <div class="modal-body">
        <turbo-frame id="lyrics_frame" data-lyrics-modal-target="frame">
          <p style="color: var(--text-muted); text-align: center; padding: 2rem 0;">Loading...</p>
        </turbo-frame>
      </div>
    </div>
  </div>
</div>
