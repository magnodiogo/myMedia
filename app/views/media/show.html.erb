<div class="page-header">
  <div>
    <span class="media-badge" style="margin-bottom: 0.5rem;"><%= @media.media_type.name %></span>
    <h1 class="page-title"><%= @media.title %></h1>
    <p class="page-subtitle">by <%= @media.artist %></p>
  </div>
  <div style="display: flex; gap: 0.5rem; align-items: center;">
    <a href="<%= edit_media_path(@media) %>" class="btn btn-secondary">Edit</a>
    <%= button_to "Delete", media_path(@media), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
    <a href="<%= media_index_path %>" class="btn btn-secondary">Back</a>
  </div>
</div>

<div class="spec-card" style="display: flex; gap: 3rem; align-items: flex-start; flex-wrap: wrap;">
  <% if @media.cover_image.attached? %>
    <div style="flex-shrink: 0; width: 260px; height: 260px; border-radius: var(--border-radius); overflow: hidden; border: 1px solid var(--panel-border); box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);">
      <%= image_tag @media.cover_image, style: "width: 100%; height: 100%; object-fit: cover;" %>
    </div>
  <% else %>
    <div class="media-card-cover-placeholder" style="flex-shrink: 0; width: 260px; height: 260px; border-radius: var(--border-radius); border: 1px solid var(--panel-border); box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3); display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgba(20, 26, 45, 0.8) 0%, rgba(30, 41, 59, 0.8) 100%);">
      <span class="placeholder-icon" style="font-size: 4rem;">🎵</span>
    </div>
  <% end %>

  <div style="flex: 1; min-width: 280px;">
    <div class="spec-header" style="margin-top: 0; border-bottom: 1px solid var(--panel-border); padding-bottom: 1rem; margin-bottom: 1.5rem;">
      <h2 style="font-size: 1.4rem; color: #a5b4fc; font-weight: 600;">Technical Specifications</h2>
    </div>

    <div class="spec-grid">
      <div class="spec-item">
        <span class="spec-label">Format / Media Type</span>
        <span class="spec-value" style="color: #c7d2fe;"><%= @media.media_type.name %></span>
      </div>

      <div class="spec-item">
        <span class="spec-label">Release Year</span>
        <span class="spec-value"><%= @media.release_year.presence || "Unknown" %></span>
      </div>

      <div class="spec-item">
        <span class="spec-label">Catalog Number</span>
        <span class="spec-value" style="font-family: monospace;"><%= @media.catalog_number.presence || "N/A" %></span>
      </div>

      <div class="spec-item">
        <span class="spec-label">Barcode</span>
        <span class="spec-value" style="font-family: monospace;"><%= @media.barcode.presence || "N/A" %></span>
      </div>
    </div>

    <% if @media.notes.present? %>
      <div class="spec-notes" style="border-top: 1px solid var(--panel-border); padding-top: 1.5rem; margin-top: 1.5rem;">
        <h3 style="font-size: 1.1rem; color: #a5b4fc; margin-bottom: 0.75rem; font-weight: 600;">Collector Notes</h3>
        <p style="color: var(--text-muted); line-height: 1.6; font-size: 0.95rem; white-space: pre-wrap;"><%= @media.notes %></p>
      </div>
    <% end %>
  </div>
</div>
