<% content_for :main_content_class, "main-content-full" %>

<div data-controller="view-toggle catalog-actions" data-catalog-actions-admin-value="<%= current_user&.admin? ? 'true' : 'false' %>">
  
  <div class="mobile-catalog-header">
    <div>
      <h1 class="mobile-page-title">Media</h1>
      <p class="mobile-page-subtitle">Your collection</p>
    </div>
    
    <div class="mobile-view-toggle-group">
      <button class="mobile-toggle-btn <%= 'active' unless @view_preference == 'simple' %>" data-action="click->view-toggle#setDetailed" data-view-toggle-target="detailedBtn">
        📝 List
      </button>
      <button class="mobile-toggle-btn <%= 'active' if @view_preference == 'simple' %>" data-action="click->view-toggle#setSimple" data-view-toggle-target="simpleBtn">
        🖼️ Grid
      </button>
    </div>
  </div>

  <!-- Search Bar -->
  <div class="mobile-search-bar">
    <%= form_with(url: media_index_path, method: :get, local: true, class: "mobile-search-form") do |form| %>
      <div class="mobile-search-input-wrapper">
        <span class="mobile-search-icon">🔍</span>
        <%= form.text_field :search, value: @query, placeholder: "Search title or artist...", class: "mobile-search-input" %>
      </div>
      <%= form.submit "Search", class: "btn-mobile-search", name: nil %>
      <% if @query.present? %>
        <a href="<%= media_index_path %>" class="btn-mobile-clear">×</a>
      <% end %>
    <% end %>
  </div>

  <!-- Hidden Size Slider (Required target for view-toggle controller) -->
  <div data-view-toggle-target="sliderContainer" class="mobile-hidden-slider" style="display: none !important;">
    <input type="range" min="120" max="300" value="<%= @media_card_size %>" data-view-toggle-target="slider" data-action="input->view-toggle#changeSize change->view-toggle#saveSize">
  </div>

  <% if @media.any? %>
    <div class="catalog-grid-mobile <%= 'grid-simple' if @view_preference == 'simple' %>" data-view-toggle-target="grid">
      <% @media.each do |media| %>
        <div class="mobile-media-card">
          <!-- Cover -->
          <div class="mobile-media-card-cover-wrapper">
            <% if media.cover_image.attached? %>
              <a href="<%= media_path(media) %>" class="mobile-media-card-cover-link">
                <%= image_tag media.cover_image, class: "mobile-media-card-cover" %>
              </a>
            <% else %>
              <a href="<%= media_path(media) %>" class="mobile-media-card-cover-link">
                <div class="mobile-media-card-cover-placeholder">🎵</div>
              </a>
            <% end %>
          </div>

          <!-- Content -->
          <div class="mobile-media-card-content">
            <div class="mobile-media-card-info">
              <span class="mobile-media-badge"><%= media.media_type.name %></span>
              <h2 class="mobile-media-title"><%= media.title %></h2>
              <p class="mobile-media-artist"><%= link_to media.artist.name, artist_path(media.artist), style: "color: inherit; text-decoration: none;" %></p>
            </div>
            
            <div class="mobile-media-actions">
              <a href="<%= media_path(media) %>" class="btn-mobile-action">Details</a>
              <% if current_user&.admin? %>
                <a href="<%= edit_media_path(media) %>" class="btn-mobile-action secondary">Edit</a>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="mobile-empty-state" style="padding: 4rem 2rem;">
      <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 1.5rem;">No media items found in your collection.</p>
    </div>
  <% end %>

  <!-- Floating Action Button (FAB) Menu -->
  <% if current_user %>
    <div class="fab-container">
      <div class="fab-menu" data-catalog-actions-target="fabMenu">
        <button type="button" class="fab-menu-item" data-action="click->catalog-actions#openBarcodeModal">
          ⚡ Add via Barcode
        </button>
        <button type="button" class="fab-menu-item" data-action="click->catalog-actions#openSearchModal">
          🔍 Online Search & Import
        </button>
      </div>
      <button class="fab-btn" data-catalog-actions-target="fabBtn" data-action="click->catalog-actions#toggleMenu">
        +
      </button>
    </div>
  <% end %>

  <!-- Barcode Lookup Modal -->
  <%= render "barcode_modal" %>

  <!-- Search & Import Modal -->
  <%= render "search_modal" %>

</div>
