<%= form_with(model: media, local: true, html: { data: { controller: "cover-search submit-status barcode-lookup" } }) do |form| %>
  <%= form.hidden_field :cover_url, data: { cover_search_target: "urlInput", barcode_lookup_target: "coverUrl" } %>
  <% if media.errors.any? %>
    <div class="error-messages">
      <h2><%= pluralize(media.errors.count, "error") %> prohibited this media from being saved:</h2>
      <ul>
        <% media.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Quick Barcode Fill Section -->
  <div class="quick-barcode-box">
    <h3 class="quick-barcode-title">
      ⚡ Quick Barcode Fill
    </h3>
    <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem; margin-top: 0.25rem;">
      Enter a barcode (UPC/EAN) to search online databases and autofill album and edition details.
    </p>
    <div style="display: flex; gap: 0.75rem;">
      <input type="text" data-barcode-lookup-target="query" placeholder="e.g., 077774600121" class="form-control" style="flex: 1;" value="<%= media.barcode %>">
      <button type="button" data-barcode-lookup-target="searchButton" data-action="click->barcode-lookup#lookup" class="btn btn-primary" style="white-space: nowrap;">
        🔍 Lookup Barcode
      </button>
    </div>
    <div data-barcode-lookup-target="status" style="margin-top: 0.75rem;"></div>
  </div>

  <div class="form-group">
    <%= form.label :media_type_id, "Physical Format", class: "form-label" %>
    <%= form.collection_select :media_type_id, MediaType.all, :id, :name, { prompt: "Select a format..." }, { class: "form-control" } %>
  </div>

  <div class="form-group">
    <%= form.label :cover_image, "Cover Art", class: "form-label" %>
    <%= form.file_field :cover_image, class: "form-control" %>
    
    <div class="cover-preview-box">
      <button type="button" class="btn btn-secondary btn-sm" data-action="click->cover-search#search">🔍 Search Cover Online</button>
      <div data-cover-search-target="preview" data-barcode-lookup-target="preview">
        <% if media.cover_image.attached? %>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <%= image_tag media.cover_image, class: "cover-preview-image" %>
            <span class="cover-preview-text">Current cover image</span>
          </div>
        <% end %>
      </div>
    </div>
    <div data-cover-search-target="results"></div>
  </div>

  <div class="form-group">
    <%= form.label :title, "Album Title", class: "form-label" %>
    <%= form.text_field :title, class: "form-control", placeholder: "e.g., The Dark Side of the Moon", data: { cover_search_target: "title", barcode_lookup_target: "title" } %>
  </div>

  <div class="form-group">
    <%= form.label :artist, class: "form-label" %>
    <%= form.text_field :artist, class: "form-control", placeholder: "e.g., Pink Floyd", list: "artists-list", data: { cover_search_target: "artist", barcode_lookup_target: "artist" } %>
    <datalist id="artists-list">
      <% Artist.order(:name).pluck(:name).each do |name| %>
        <option value="<%= name %>"></option>
      <% end %>
    </datalist>
  </div>

  <div class="form-group">
    <%= form.label :release_year, "Edition Release Year", class: "form-label" %>
    <%= form.number_field :release_year, class: "form-control", placeholder: "e.g., 1973", data: { barcode_lookup_target: "year" } %>
  </div>

  <div class="form-group">
    <%= form.label :catalog_number, "Catalog Number", class: "form-label" %>
    <%= form.text_field :catalog_number, class: "form-control", placeholder: "e.g., CDP 7 46001 2", data: { barcode_lookup_target: "catalog" } %>
  </div>

  <div class="form-group">
    <%= form.label :barcode, class: "form-label" %>
    <%= form.text_field :barcode, class: "form-control", placeholder: "e.g., 077774600121", data: { barcode_lookup_target: "barcode" } %>
  </div>

  <div class="form-group">
    <%= form.label :allmusic_url, "AllMusic Album URL", class: "form-label" %>
    <%= form.url_field :allmusic_url, class: "form-control", placeholder: "https://www.allmusic.com/album/i-still-do-mw0002922480" %>
  </div>

  <div class="form-group">
    <%= form.label :notes, "Edition Notes", class: "form-label" %>
    <%= form.text_area :notes, rows: 4, class: "form-control", placeholder: "Add details about this pressing, remaster, packaging, or source..." %>
  </div>

  <div class="form-actions">
    <a href="<%= media_index_path %>" class="btn btn-secondary">Cancel</a>
    <%= form.submit class: "btn btn-primary", data: { submit_status_target: "submitButton" } %>
  </div>

  <!-- Submission Progress Modal -->
  <div data-submit-status-target="modal" class="submit-modal-overlay">
    <div class="submit-modal-content">
      <div class="submit-modal-header">
        <div class="spinner"></div>
        <h3>Processing Physical Media</h3>
      </div>
      <ul class="submit-steps-list">
        <li data-submit-status-target="validationStep" class="step-pending">
          <span class="step-icon">⏳</span> Validating details...
        </li>
        <li data-submit-status-target="imageStep" class="step-pending">
          <span class="step-icon">⏳</span> Processing cover image (600x600)...
        </li>
        <li data-submit-status-target="saveStep" class="step-pending">
          <span class="step-icon">⏳</span> Saving to database...
        </li>
      </ul>
    </div>
  </div>
<% end %>
