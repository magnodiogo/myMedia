<!DOCTYPE html>
<html>
  <head>
    <title>myMedia Collection</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      if (localStorage.getItem("theme") === "light") {
        document.documentElement.classList.add("light-theme");
      }
    </script>
  </head>

  <body>
    <div class="app-container" data-controller="theme">
      <aside class="sidebar">
        <a href="<%= root_path %>" class="logo-container">
          <div class="logo-icon">🎵</div>
          <span class="logo-text">myMedia</span>
        </a>

        <nav>
          <ul class="nav-links">
            <li>
              <a href="<%= root_path %>" class="nav-link <%= 'active' if controller_name == 'dashboard' %>">
                <span class="nav-icon">📊</span> Dashboard
              </a>
            </li>
            <li>
              <a href="<%= media_index_path %>" class="nav-link <%= 'active' if controller_name == 'media' %>">
                <span class="nav-icon">💿</span> Media Collection
              </a>
            </li>
            <li>
              <a href="<%= media_types_path %>" class="nav-link <%= 'active' if controller_name == 'media_types' %>">
                <span class="nav-icon">🏷️</span> Media Types
              </a>
            </li>
          </ul>
        </nav>

        <div class="theme-toggle-container">
          <button class="theme-toggle-btn" data-theme-target="button" data-action="click->theme#toggle">
            <span class="nav-icon">☀️</span> Light Mode
          </button>
        </div>
      </aside>

      <main class="main-content">
        <% flash.each do |type, message| %>
          <div class="flash-message flash-<%= type %>">
            <% if type == 'notice' %>
              <span>✓</span>
            <% else %>
              <span>⚠</span>
            <% end %>
            <%= message %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
