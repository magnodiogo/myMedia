<!DOCTYPE html>
<html class="<%= 'light-theme' if @theme == 'light' %>">
  <head>
    <title>myMedia Physical Collection</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      // Fallback for first load
      if (!document.cookie.includes("theme=") && localStorage.getItem("theme") === "light") {
        document.documentElement.classList.add("light-theme");
      }
    </script>
  </head>

  <body>
    <div class="app-container <%= 'sidebar-collapsed' if @sidebar_collapsed %>" data-controller="theme sidebar">
      <!-- Mobile Hamburger Toggle Button -->
      <% unless devise_controller? %>
        <button type="button" class="mobile-nav-toggle-btn" data-action="click->sidebar#toggleMobile" title="Menu" style="position: fixed; top: 1.5rem; left: 1.5rem; z-index: 1000; background: var(--panel-bg); border: 1px solid var(--panel-border); color: var(--text-main); width: 44px; height: 44px; border-radius: 50%; display: none; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.3); backdrop-filter: blur(12px); padding: 0;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 22px; height: 22px; pointer-events: none;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>

        <!-- Sidebar Backdrop overlay for mobile -->
        <div class="sidebar-backdrop" data-action="click->sidebar#toggleMobile" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99; display: none; backdrop-filter: blur(4px);"></div>
      <% end %>
      <% unless devise_controller? %>
        <aside class="sidebar">
          <a href="<%= root_path %>" class="logo-container">
            <%= image_tag "/logo.png", class: "app-logo", alt: "myMedia" %>
          </a>

          <nav>
            <ul class="nav-links">
              <li>
                <a href="<%= root_path %>" class="nav-link <%= 'active' if controller_name == 'dashboard' %>">
                  <span class="nav-icon">📊</span> <span class="nav-text">Dashboard</span>
                </a>
              </li>
              <li>
                <a href="<%= media_index_path %>" class="nav-link <%= 'active' if controller_name == 'media' %>">
                  <span class="nav-icon">💿</span> <span class="nav-text">Physical Media</span>
                </a>
              </li>
              <li>
                <a href="<%= media_types_path %>" class="nav-link <%= 'active' if controller_name == 'media_types' %>">
                  <span class="nav-icon">🏷️</span> <span class="nav-text">Physical Formats</span>
                </a>
              </li>
              <li>
                <a href="<%= artists_path %>" class="nav-link <%= 'active' if controller_name == 'artists' %>">
                  <span class="nav-icon">🎤</span> <span class="nav-text">Artists</span>
                </a>
              </li>
              <li>
                <a href="<%= plans_path %>" class="nav-link <%= 'active' if controller_name == 'plans' %>">
                  <span class="nav-icon">⭐</span> <span class="nav-text">Plans & Upgrades</span>
                </a>
              </li>
              <li>
                <a href="<%= notifications_path %>" class="nav-link <%= 'active' if controller_name == 'notifications' %>" style="position: relative;">
                  <span class="nav-icon">🔔</span> 
                  <span class="nav-text">Notifications</span>
                  <% if current_user %>
                    <% unread_count = current_user.notifications.unread.count %>
                    <% if unread_count > 0 %>
                      <span style="background-color: var(--danger-color); color: white; border-radius: 12px; padding: 0.15rem 0.5rem; font-size: 0.72rem; font-weight: bold; position: absolute; right: 1.25rem; top: 50%; transform: translateY(-50%); box-shadow: 0 0 8px rgba(239, 68, 68, 0.4);">
                        <%= unread_count %>
                      </span>
                    <% end %>
                  <% end %>
                </a>
              </li>
            </ul>
          </nav>

          <!-- User Selector & Info -->
          <% if current_user %>
            <div class="active-user-container" style="margin-top: auto; margin-bottom: 1rem; border-top: 1px solid var(--panel-border); padding-top: 1.5rem;">
              <div style="display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 1rem;">
                <span style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Logged in as</span>
                <span style="font-weight: 600; color: var(--text-main);"><%= current_user.name.presence || current_user.email %></span>
                
                <div style="display: flex; align-items: center; gap: 0.4rem; margin-top: 0.25rem;">
                  <span class="media-badge" style="font-size: 0.7rem; padding: 0.15rem 0.5rem; margin: 0;"><%= current_user.type %></span>
                  <% if current_user.free_tier? %>
                    <span class="media-badge" style="font-size: 0.7rem; padding: 0.15rem 0.5rem; margin: 0; background-color: rgba(255,255,255,0.05); border-color: var(--panel-border); color: var(--text-muted);">FREE</span>
                  <% else %>
                    <span class="media-badge" style="font-size: 0.7rem; padding: 0.15rem 0.5rem; margin: 0; background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%); border-color: transparent; color: white; font-weight: bold; box-shadow: 0 2px 8px rgba(168, 85, 247, 0.3);">PREMIUM</span>
                  <% end %>
                </div>

                <% if current_user.free_tier? %>
                  <div style="margin-top: 0.5rem; font-size: 0.75rem;">
                    <div style="display: flex; justify-content: space-between; color: var(--text-muted); margin-bottom: 0.25rem;">
                      <span>Media limit:</span>
                      <span style="font-weight: 600; color: var(--text-main);"><%= @collection_count %> / <%= @collection_limit %></span>
                    </div>
                    <div class="format-progress-bar-bg" style="height: 6px; border-radius: 3px;">
                      <% pct = @collection_limit > 0 ? (@collection_count.to_f / @collection_limit * 100).round : 0 %>
                      <div class="format-progress-bar-fill" style="width: <%= [pct, 100].min %>%; height: 6px; border-radius: 3px; background: <%= pct >= 100 ? 'var(--danger-color)' : 'var(--accent-primary)' %>;"></div>
                    </div>
                  </div>
                <% else %>
                  <div style="margin-top: 0.4rem; font-size: 0.75rem; color: var(--accent-secondary); font-weight: 600;">
                    ✓ Unlimited Collection
                  </div>
                <% end %>
              </div>

              <!-- Dev user switcher shortcut -->
              <form action="<%= switch_user_sessions_path %>" method="post" class="active-user-form" style="margin-bottom: 1rem;">
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                <label for="user_id" class="active-user-label" style="font-size: 0.75rem;">Switch User (Dev)</label>
                <div class="active-user-select-wrapper">
                  <span class="active-user-icon">🔄</span>
                  <select name="user_id" id="user_id" onchange="this.form.submit()" class="active-user-select">
                    <% User.all.each do |u| %>
                      <option value="<%= u.id %>" <%= 'selected' if current_user == u %>><%= u.name.presence || u.email %></option>
                    <% end %>
                  </select>
                </div>
              </form>

              <%= button_to "🚪 Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-secondary btn-sm", style: "width: 100%; justify-content: center;", data: { turbo: false } %>
            </div>
          <% end %>

          <!-- Collapse Button -->
          <div class="sidebar-toggle-container" style="border-top: 1px solid var(--panel-border); margin-top: 0.5rem; padding-top: 0.5rem; width: 100%;">
            <button type="button" class="sidebar-toggle-btn" data-action="click->sidebar#toggle" title="Toggle Sidebar" style="background: rgba(255, 255, 255, 0.03); border: 1px solid var(--panel-border); color: var(--text-muted); cursor: pointer; padding: 0.5rem 1rem; display: flex; align-items: center; justify-content: center; width: 100%; border-radius: var(--border-radius); transition: all var(--transition-speed) ease;">
              <span data-sidebar-target="icon" style="font-size: 1rem; font-weight: bold;"><%= @sidebar_collapsed ? "▶" : "◀" %></span>
            </button>
          </div>

          <div class="theme-toggle-container" style="width: 100%;">
            <button class="theme-toggle-btn" data-theme-target="button" data-action="click->theme#toggle">
              <span class="nav-icon">☀️</span> <span class="theme-toggle-text">Light Mode</span>
            </button>
          </div>
        </aside>
      <% end %>

      <main class="main-content <%= 'main-content-full' if devise_controller? %> <%= yield :main_content_class %>" style="<%= 'margin-left: 0; width: 100%;' if devise_controller? %>">
        <% flash.each do |type, message| %>
          <div class="flash-message flash-<%= type %>">
            <% if type == 'notice' %>
              <span>✓</span>
            <% else %>
              <span>⚠</span>
            <% end %>
            <%= message %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
