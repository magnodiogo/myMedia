<div class="page-header">
  <div>
    <h1 class="page-title"><%= @media_type.name %></h1>
    <p class="page-subtitle">Physical format overview and edition catalog</p>
  </div>
  <div style="display: flex; gap: 0.5rem;">
    <% if current_user&.admin? %>
      <a href="<%= edit_media_type_path(@media_type) %>" class="btn btn-secondary">Edit Format</a>
    <% end %>
    <a href="<%= media_types_path %>" class="btn btn-secondary">Back</a>
  </div>
</div>

<div class="stats-grid" style="margin-bottom: 2rem;">
  <div class="stat-card">
    <div class="stat-icon-bg">💿</div>
    <div class="stat-info">
      <div class="stat-label">Total Editions in Format</div>
      <div class="stat-value"><%= @media.count %></div>
    </div>
  </div>
</div>

<div class="section-box" style="margin-bottom: 2rem;">
  <h3 style="border: none; margin-bottom: 0.5rem; padding-bottom: 0; font-size: 1.1rem; color: #a5b4fc;">Description</h3>
  <p style="color: var(--text-muted); line-height: 1.6; font-size: 0.95rem;"><%= @media_type.description.presence || "No description provided for this format." %></p>
</div>

<div class="section-box">
  <h3>Editions in this Format</h3>
  <% if @media.any? %>
    <table class="custom-table">
      <thead>
        <tr>
          <th>Album</th>
          <th>Edition</th>
          <th>Artist</th>
          <th>Year</th>
          <th>Catalog Number</th>
          <th style="text-align: right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @media.each do |item| %>
          <tr>
            <td style="font-weight: 600; color: var(--text-main);"><%= item.album&.title || item.title %></td>
            <td style="color: var(--text-muted);"><%= item.title %></td>
            <td style="color: var(--text-muted);"><%= link_to item.artist.name, artist_path(item.artist), style: "color: #a5b4fc; text-decoration: none;" %></td>
            <td style="color: var(--text-muted);"><%= item.release_year %></td>
            <td style="font-family: monospace; color: var(--text-muted);"><%= item.catalog_number %></td>
            <td style="text-align: right;">
              <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                <a href="<%= media_path(item) %>" class="btn btn-secondary btn-sm">Details</a>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="color: var(--text-muted); padding: 1rem 0;">No editions in this format yet.</p>
  <% end %>
</div>
