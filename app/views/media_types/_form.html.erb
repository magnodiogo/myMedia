<%= form_with(model: media_type, local: true) do |form| %>
  <% if media_type.errors.any? %>
    <div class="error-messages">
      <h2><%= pluralize(media_type.errors.count, "error") %> prohibited this media type from being saved:</h2>
      <ul>
        <% media_type.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: "e.g., CD RedBook, Vinyl LP..." %>
  </div>

  <div class="form-group">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, rows: 4, class: "form-control", placeholder: "Describe the characteristics of this media format..." %>
  </div>

  <div class="form-actions">
    <a href="<%= media_types_path %>" class="btn btn-secondary">Cancel</a>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
