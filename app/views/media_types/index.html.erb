<div class="page-header">
  <div>
    <h1 class="page-title">Physical Formats</h1>
    <p class="page-subtitle">Configure formats/types for your media collection</p>
  </div>
  <% if current_user&.admin? %>
    <a href="<%= new_media_type_path %>" class="btn btn-primary">+ Add Physical Format</a>
  <% end %>
</div>

<div class="section-box">
  <% if @media_types.any? %>
    <table class="custom-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th style="text-align: right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @media_types.each do |media_type| %>
          <tr>
            <td style="font-weight: 600; color: #a5b4fc;"><%= media_type.name %></td>
            <td style="color: var(--text-muted);"><%= media_type.description %></td>
            <td style="text-align: right;">
              <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                <a href="<%= media_type_path(media_type) %>" class="btn btn-secondary btn-sm">View</a>
                <% if current_user&.admin? %>
                  <a href="<%= edit_media_type_path(media_type) %>" class="btn btn-secondary btn-sm">Edit</a>
                  <%= button_to "Delete", media_type_path(media_type), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <% if current_user&.admin? %>
      <p style="color: var(--text-muted); padding: 1rem 0;">No physical formats defined yet. Click "+ Add Physical Format" to create one.</p>
    <% else %>
      <p style="color: var(--text-muted); padding: 1rem 0;">No media types defined yet.</p>
    <% end %>
  <% end %>
</div>
