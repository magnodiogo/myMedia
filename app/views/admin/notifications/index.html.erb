<div class="page-header">
  <div>
    <h1 class="page-title">Manage Notifications</h1>
    <p class="page-subtitle">Send announcements, promotions, and targeted alerts to collectors</p>
  </div>
  <div>
    <a href="<%= new_admin_notification_path %>" class="btn btn-primary">+ Compose Notification</a>
  </div>
</div>

<div class="section-box" style="padding: 1.5rem;">
  <% if @notifications.any? %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Sent To</th>
          <th>Notification Details</th>
          <th style="width: 100px; text-align: center;">Status</th>
          <th style="width: 150px; text-align: right;">Sent At</th>
          <th style="width: 80px; text-align: center;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @notifications.each do |n| %>
          <tr>
            <td>
              <div style="font-weight: 600; color: var(--text-main);">
                <%= n.user&.name.presence || n.user&.email %>
              </div>
              <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.15rem;">
                <%= n.user&.email %>
              </div>
            </td>
            <td>
              <div style="font-weight: 700; color: var(--text-main); margin-bottom: 0.25rem;"><%= n.title %></div>
              <div style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; max-width: 500px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                <%= n.content %>
              </div>
            </td>
            <td style="text-align: center;">
              <% if n.read? %>
                <span class="media-badge" style="background-color: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.3); color: #34d399; font-size: 0.68rem; margin: 0; padding: 0.1rem 0.4rem;">Read</span>
              <% else %>
                <span class="media-badge" style="background-color: rgba(245, 158, 11, 0.1); border-color: rgba(245, 158, 11, 0.3); color: #fbbf24; font-size: 0.68rem; margin: 0; padding: 0.1rem 0.4rem;">Unread</span>
              <% end %>
            </td>
            <td style="text-align: right; color: var(--text-muted); font-size: 0.8rem;">
              <%= time_ago_in_words(n.created_at) %> ago
            </td>
            <td style="text-align: center;">
              <%= button_to admin_notification_path(n), method: :delete, class: "btn btn-danger btn-sm", style: "background-color: rgba(239, 68, 68, 0.05); border-color: rgba(239, 68, 68, 0.15); font-size: 0.8rem; padding: 0.3rem 0.6rem;", data: { confirm: "Are you sure you want to delete this notification?" } do %>
                🗑️
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div style="text-align: center; padding: 3rem 1.5rem; color: var(--text-muted);">
      <div style="font-size: 3rem; margin-bottom: 1rem;">📣</div>
      <h3 style="margin-bottom: 0.5rem; font-weight: 600; color: var(--text-main);">No Notifications Sent</h3>
      <p style="font-size: 0.9rem; margin-bottom: 1.5rem;">Create a notification to announce promotions or alert users of custom notices.</p>
      <a href="<%= new_admin_notification_path %>" class="btn btn-primary">+ Send First Notification</a>
    </div>
  <% end %>
</div>
